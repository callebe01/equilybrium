export default function HowItWorks() {
  const { ref, visible } = useInView(0.08);

  return (
    <section
      ref={ref}
      className="relative overflow-hidden"
      style={{
        background: 'var(--cream)',
        padding: '140px 48px',
      }}
    >
      <div style={{ maxWidth: '1200px', margin: '0 auto', width: '100%' }}>
        {/* Section header — left aligned */}
        <div
